---
import Layout from '../layouts/Layout.astro';
import trailMarkers from '../data/trail-markers.json';
---

<Layout
  title="Prayer Walk"
  description="Walk the John Hendrix Memorial Prayer Walk — a ½-mile nature trail along Hendrix Creek in Oak Ridge, Tennessee with eight historical trail markers."
>

  <!-- Hero -->
  <section class="bg-forest-textured text-parchment py-20 hero-border">
    <div class="section-container">
      <span class="eyebrow-light">Oak Ridge, Tennessee</span>
      <h1 class="font-display text-section text-parchment mb-4">John Hendrix Memorial<br />Prayer Walk</h1>
      <p class="text-parchment-dark text-lg max-w-xl">
        A historic ½-mile nature trail commemorating the story of John Hendrix
        and the community whose sacrifice helped win World War II.
      </p>
    </div>
  </section>

<!-- Carousel -->
<section class="bg-parchment-dark py-0">
  <div class="relative overflow-hidden" id="pw-carousel" aria-label="Prayer Walk photo gallery">

    <!-- Slides -->
    <div class="flex transition-transform duration-700 ease-in-out" id="pw-track">
      {[
        { src: "/images/prayer-walk-entrance.jpg",   alt: "Entrance to the John Hendrix Memorial Prayer Walk" },
        { src: "/images/prayer-walk-roses.jpg",      alt: "Rose bushes along the prayer walk" },
        { src: "/images/small-bridge-at-heritage.jpg", alt: "Small bridge at Heritage" },
        { src: "/images/racoon-in-tree.jpg",         alt: "Raccoon in a tree along the trail" },
        { src: "/images/crane-on-prayer-walk.jpg",   alt: "Crane on the prayer walk" },
        { src: "/images/jack-at-wagon.jpg",          alt: "Jack at the wagon" },
        { src: "/images/railroad-tracks.jpg",        alt: "Railroad tracks beside the old farm site" },
      ].map((img) => (
        <div class="w-full shrink-0 aspect-[4/3] bg-ink overflow-hidden">
          <img
            src={img.src}
            alt={img.alt}
            class="w-full h-full object-cover"
            loading="lazy"
          />
        </div>
      ))}
    </div>

    <!-- Prev / Next buttons -->
    <button
      id="pw-prev"
      aria-label="Previous photo"
      class="absolute left-3 top-1/2 -translate-y-1/2 z-10 bg-parchment/80 hover:bg-parchment text-forest rounded-full p-2 shadow transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
      </svg>
    </button>
    <button
      id="pw-next"
      aria-label="Next photo"
      class="absolute right-3 top-1/2 -translate-y-1/2 z-10 bg-parchment/80 hover:bg-parchment text-forest rounded-full p-2 shadow transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
      </svg>
    </button>

    <!-- Dot indicators -->
    <div class="absolute bottom-3 left-1/2 -translate-x-1/2 flex gap-2 z-10" id="pw-dots"></div>
  </div>
</section>

  <!-- Trail intro -->
  <section class="section-pad bg-parchment">
    <div class="section-container">
      <p class="text-ink-soft text-lg leading-relaxed mb-6">
        As you meander along Hendrix Creek you will discover eight trail markers which tell the story
        of a farmer named John who came to be called "The Prophet of Oak Ridge." You will hear the
        story of a community who gave up their land for the secret city now called Oak Ridge, Tennessee —
        where the uranium was produced for the first atomic bombs so the massive killings of WWII
        could be brought to an end.
      </p>
      <p class="text-ink-soft text-lg leading-relaxed">
        Along the trail you may watch for wildlife, hear the water running down the creek, look for
        the Hendrix rose bushes and wildflowers, fruit trees, chestnuts, and periwinkle ground cover
        in bloom. Several benches are available to rest along the trail. Train tracks still lay right
        beside John Hendrix's old farm site.
      </p>
    </div>
  </section>

  <!-- Trail markers accordion -->
  <section class="section-pad bg-parchment-dark">
    <div class="section-container">
      <span class="eyebrow">Along the Trail</span>
      <h2 class="font-display text-section text-forest mb-10">Eight Trail Markers</h2>

      <div class="space-y-3" id="trail-accordion">
        {trailMarkers.map((marker) => (
          <div class="border border-stone-light rounded-sm overflow-hidden bg-parchment">
            <button
              class="w-full flex items-center justify-between px-6 py-4 text-left hover:bg-parchment-dark transition-colors min-h-[56px]"
              aria-expanded="false"
              data-accordion-trigger
            >
              <span class="flex items-center gap-4">
                <span class="font-ui text-xs text-copper font-semibold tracking-widest uppercase w-6">
                  {String(marker.id).padStart(2, '0')}
                </span>
                <span class="font-display text-lg text-forest">{marker.title}</span>
              </span>
              <svg class="h-5 w-5 text-stone shrink-0 transition-transform duration-200" data-chevron xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </button>
            <div class="hidden px-6 pb-5 pt-1 border-t border-stone-light" data-accordion-content>
              <p class="text-ink-soft leading-relaxed">{marker.description}</p>
              {marker.imageUrl && (
                <img
                  src={marker.imageUrl}
                  alt={marker.imageAlt}
                  loading="lazy"
                  class="mt-4 rounded-sm w-full max-w-md"
                />
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Gravesite section -->
  <section class="section-pad bg-parchment">
    <div class="section-container">
      <span class="eyebrow">After the Walk</span>
      <h2 class="font-display text-section text-forest mb-6">John's Gravesite</h2>
      <p class="text-ink-soft text-lg leading-relaxed max-w-2xl mb-8">
        After finishing the trail, venture up the street to John's gravesite, located to the left
        of 127 Hendrix Drive. Until recently a boxwood bush planted there by John's six-year-old son
        Curtis when John died in 1915 grew to billow 50+ feet in the air. A local school group
        purchased the gravestone in 1970.
      </p>
      <a href="/find-us" class="btn-primary">Get Directions to the Trail</a>
    </div>
  </section>

</Layout>

<script>
  // ── Accordion ──────────────────────────────────────────────────
  document.querySelectorAll('[data-accordion-trigger]').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const content = trigger.nextElementSibling as HTMLElement;
      const chevron = trigger.querySelector('[data-chevron]') as HTMLElement;
      const isOpen = !content.classList.contains('hidden');
      content.classList.toggle('hidden', isOpen);
      chevron.style.transform = isOpen ? '' : 'rotate(180deg)';
      trigger.setAttribute('aria-expanded', String(!isOpen));
    });
  });

  // ── Carousel ───────────────────────────────────────────────────
  const track   = document.getElementById('pw-track') as HTMLElement;
  const dotsEl  = document.getElementById('pw-dots')  as HTMLElement;
  const total   = track?.children.length ?? 0;
  let current   = 0;
  let timer: ReturnType<typeof setInterval>;

  // Build dots
  for (let i = 0; i < total; i++) {
    const d = document.createElement('button');
    d.className = 'w-2 h-2 rounded-full bg-parchment/50 transition-colors';
    d.setAttribute('aria-label', `Go to photo ${i + 1}`);
    d.addEventListener('click', () => goTo(i));
    dotsEl.appendChild(d);
  }

  function goTo(index: number) {
    current = (index + total) % total;
    track.style.transform = `translateX(-${current * 100}%)`;
    dotsEl.querySelectorAll('button').forEach((d, i) => {
      (d as HTMLElement).className = i === current
        ? 'w-2 h-2 rounded-full bg-parchment transition-colors'
        : 'w-2 h-2 rounded-full bg-parchment/50 transition-colors';
    });
    resetTimer();
  }

  function resetTimer() {
    clearInterval(timer);
    timer = setInterval(() => goTo(current + 1), 4000);
  }

  document.getElementById('pw-prev')?.addEventListener('click', () => goTo(current - 1));
  document.getElementById('pw-next')?.addEventListener('click', () => goTo(current + 1));

  goTo(0); // init dots + start autoplay

  // Pause on hover / focus
  const carousel = document.getElementById('pw-carousel');
  carousel?.addEventListener('mouseenter', () => clearInterval(timer));
  carousel?.addEventListener('mouseleave', () => resetTimer());
</script>
